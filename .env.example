# ── Gemini AI ────────────────────────────────────────────────────────────────
# Required for food analysis (text + image) and macro calculation.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── EmailJS ───────────────────────────────────────────────────────────────────
# Required for OTP delivery on signup and password reset.
# Get these from https://dashboard.emailjs.com/admin
#
# Your email template must use these variables:
#   {{to_email}}  — recipient address (set this as the "To Email" field)
#   {{otp_code}}  — the 6-digit code
#   {{app_name}}  — "Journable"
#
# NOTE: These are embedded in the browser bundle at build time and are
# visible to anyone who inspects the page. EmailJS public keys are designed
# for this — restrict allowed origins in your EmailJS dashboard.
EMAILJS_SERVICE_ID="YOUR_EMAILJS_SERVICE_ID"
EMAILJS_TEMPLATE_ID="YOUR_EMAILJS_TEMPLATE_ID"
EMAILJS_PUBLIC_KEY="YOUR_EMAILJS_PUBLIC_KEY"

# ── App URL ───────────────────────────────────────────────────────────────────
# The URL where this app is hosted (used for OAuth callbacks etc).
# AI Studio injects this automatically at runtime.
APP_URL="YOUR_APP_URL"
