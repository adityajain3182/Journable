# ── Gemini AI ────────────────────────────────────────────────────────────────
# Required for food analysis (text + image) and macro calculation.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── App URL ───────────────────────────────────────────────────────────────────
# The URL where this app is hosted (used for OAuth callbacks etc).
# AI Studio injects this automatically at runtime.
APP_URL="YOUR_APP_URL"
